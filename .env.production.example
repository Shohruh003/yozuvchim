# =====================================================================
# Yozuvchim — PRODUCTION env template
# =====================================================================
# Copy to .env on the server: cp .env.production.example .env
# Then fill in every blank below.
# Generate strong random secrets via scripts/generate-secrets.sh
# =====================================================================

# --- Public-facing domain ---------------------------------------------
PUBLIC_DOMAIN=yozuvchim.example.com
ACME_EMAIL=admin@example.com               # Let's Encrypt notifications

# --- Database (only reachable inside Docker network) ------------------
POSTGRES_USER=yozuvchim
POSTGRES_PASSWORD=                          # ▶ openssl rand -base64 32
POSTGRES_DB=yozuvchim
POSTGRES_PORT=5432                          # not exposed in prod (overlay)

# --- Redis ------------------------------------------------------------
REDIS_PORT=6379                             # not exposed in prod

# --- Backend (NestJS) -------------------------------------------------
BACKEND_PORT=3000                           # not exposed in prod
JWT_SECRET=                                 # ▶ openssl rand -base64 64
JWT_REFRESH_SECRET=                         # ▶ openssl rand -base64 64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# These are auto-set by docker-compose.prod.yml from PUBLIC_DOMAIN, but
# you can override here if you want to allow more origins.
# CORS_ORIGINS=https://yozuvchim.example.com
# WEB_APP_URL=https://yozuvchim.example.com

# --- Telegram bot -----------------------------------------------------
BOT_TOKEN=                                  # from @BotFather (production bot)
BOT_USERNAME=                               # without @
# After deploy, run /setdomain in @BotFather to point WebApp at PUBLIC_DOMAIN

# --- AI provider ------------------------------------------------------
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional secondary AI (failover)
SECONDARY_AI_API_KEY=
SECONDARY_AI_BASE_URL=https://api.openai.com/v1
SECONDARY_AI_MODEL=gpt-4o

# --- Admin & access ---------------------------------------------------
# Bootstrap superadmin Telegram IDs (comma-separated). One is enough.
SUPERADMIN_IDS=
# Optional: chat ID of a private group/channel where every finished order
# is auto-forwarded as an audit copy. Leave empty to disable.
RESULTS_CHANNEL=
# Optional: public link/invite URL of that same channel. If set, the bot
# includes it in the user's delivery message (https://t.me/... or invite).
RESULTS_CHANNEL_URL=

# First-run admin login (DB seed). Change immediately via /admin/settings,
# then DELETE these two lines from .env.
ADMIN_LOGIN_USERNAME=admin
ADMIN_LOGIN_PASSWORD=                       # ▶ openssl rand -base64 24

FREE_DAILY_LIMIT=5

# --- Currency ---------------------------------------------------------
CURRENCY=UZS

# --- Optional images --------------------------------------------------
UNSPLASH_API_KEY=

# --- Frontend build-time ----------------------------------------------
# Always /api in prod (Caddy proxies same-origin)
VITE_API_URL=/api
