# ============================================================
# Yozuvchim — environment variables (copy to .env and fill in)
# ============================================================

# --- Database ---
POSTGRES_USER=yozuvchim
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=yozuvchim
POSTGRES_PORT=5434                       # host port (container is 5432)

# --- Redis ---
REDIS_PORT=6381                          # host port (container is 6379)

# --- Backend (NestJS) ---
BACKEND_PORT=3000
JWT_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,https://yozuvchim.example.com

# --- Telegram ---
BOT_TOKEN=                               # from @BotFather
BOT_USERNAME=                            # without @
WEB_APP_URL=                             # https://yozuvchim.example.com

# --- AI provider ---
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Optional: secondary AI (failover) ---
SECONDARY_AI_API_KEY=
SECONDARY_AI_BASE_URL=https://api.openai.com/v1
SECONDARY_AI_MODEL=gpt-4o

# --- Admin & access ---
# Bootstrap superadmin(s) — irrevocable, hard-coded admins.
# Other admins are promoted from the admin panel (DB-backed).
SUPERADMIN_IDS=                          # comma-separated Telegram user IDs
FREE_DAILY_LIMIT=5

# --- Payments ---
# Card details are managed via the admin panel (DB-backed).
CURRENCY=UZS

# --- Image API (optional) ---
UNSPLASH_API_KEY=

# --- Frontend build-time ---
VITE_API_URL=http://localhost:3000       # dev. Production: https://yozuvchim.example.com
